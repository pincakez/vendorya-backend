# --- Vendorya backend env (template) ---
# Copy to `.env` for local dev. Never commit `.env`.

# Django core
DJANGO_SECRET_KEY=replace-me-in-prod-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=vendorya_db
DB_USER=mysqladmin
DB_PASSWORD=replace-me
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_SIGNING_KEY=replace-me-with-a-separate-random-string

# CORS
# When DEBUG=True these defaults to allowing all origins. In prod, list comma-separated origins:
# CORS_ALLOWED_ORIGINS=https://app.vendorya.com,https://admin.vendorya.com
CORS_ALLOWED_ORIGINS=
